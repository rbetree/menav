---
import CardIcon from './CardIcon.astro';
import { extractDomain, formatDate, getSafeUrl } from '../lib/view-data/view-utils.ts';
import { toCardViewModel } from '../lib/site-model/card.ts';
import type { CardViewModel } from '../types/model';
import type { RenderContext } from '../types/render';
import { DEFAULT_RENDER_CONTEXT } from '../lib/view-data/render-context.ts';
import type { SiteItem } from '../types/site';

interface Props {
  site?: SiteItem;
  card?: CardViewModel;
  style?: string;
  type?: string;
  renderContext?: RenderContext;
}

const {
  site = {},
  card = null,
  style = '',
  type = '',
  renderContext = DEFAULT_RENDER_CONTEXT,
} = Astro.props;

const cardModel =
  card ||
  toCardViewModel({
    pageId: '',
    site,
    renderContext,
    type: type === 'article' ? 'article' : undefined,
    style,
  });
const cardType = cardModel?.type || type || site.type || 'site';
const cardStyle = cardModel?.style || style || site.style || '';
const name = cardModel?.title || site.name || '未命名站点';
const url = cardModel?.url || site.url || '#';
const icon = cardModel?.icon || site.icon || (cardStyle === 'repo' ? 'fas fa-code' : 'fas fa-link');
const description = cardModel?.description || site.description || extractDomain(url);
const safeHref = cardModel?.safeUrl || getSafeUrl(url, renderContext.allowedSchemes);
const faviconUrl = cardModel?.faviconUrl || site.faviconUrl || '';
const forceIconMode = cardModel?.forceIconMode || site.forceIconMode || '';
const tooltip = `${name} - ${description || extractDomain(url)}`;
const useExternal = cardModel?.external ?? site.external;
const shouldOpenExternal = Boolean(useExternal);
const publishedAt = cardModel?.publishedAt || site.publishedAt || '';
const source = cardModel?.source || site.source || '';
const language = cardModel?.language || site.language || '';
const languageColor = cardModel?.languageColor || site.languageColor || '';
const stars = cardModel?.stars ?? site.stars;
const forks = cardModel?.forks ?? site.forks;
const issues = cardModel?.issues ?? site.issues;
---

{
  url && (
    <a
      href={safeHref}
      class:list={['site-card', cardStyle && `site-card-${cardStyle}`]}
      target={shouldOpenExternal ? '_blank' : undefined}
      rel={shouldOpenExternal ? 'noopener' : undefined}
      data-type={cardType}
      data-name={name}
      data-url={url}
      data-icon={icon}
      data-favicon-url={faviconUrl || undefined}
      data-force-icon-mode={forceIconMode || undefined}
      data-description={description}
      data-tooltip={tooltip}
      data-published-at={publishedAt || undefined}
      data-source={source || undefined}
    >
      {cardType === 'article' ? (
        <>
          <div class="article-card-header">
            <CardIcon site={site} renderContext={renderContext} name={name} url={url} icon={icon} />
            <div class="article-card-title">
              <h3>{name}</h3>
            </div>
          </div>
          <div class="article-card-body">
            {(publishedAt || source) && (
              <div class="site-card-meta">
                {publishedAt && (
                  <span class="site-card-meta-date">{formatDate(publishedAt, 'YYYY-MM-DD')}</span>
                )}
                {publishedAt && source && <span class="site-card-meta-sep">·</span>}
                {source && <span class="site-card-meta-source">{source}</span>}
              </div>
            )}
            <p>{description}</p>
          </div>
        </>
      ) : cardStyle === 'repo' ? (
        <>
          <div class="repo-header">
            <i class:list={[icon, 'repo-icon']} aria-hidden="true" />
            <div class="repo-title">{name}</div>
          </div>
          <div class="repo-desc">{description}</div>
          {(language || stars || forks || issues) && (
            <div class="repo-stats">
              {language && (
                <div class="stat-item">
                  <span
                    class="lang-dot"
                    style={`background-color: ${languageColor || '#909296'};`}
                  />
                  {language}
                </div>
              )}
              {stars && (
                <div class="stat-item">
                  <i class="far fa-star" aria-hidden="true" /> {stars}
                </div>
              )}
              {forks && (
                <div class="stat-item">
                  <i class="fas fa-code-branch" aria-hidden="true" /> {forks}
                </div>
              )}
              {issues && (
                <div class="stat-item">
                  <i class="fas fa-exclamation-circle" aria-hidden="true" /> {issues}
                </div>
              )}
            </div>
          )}
        </>
      ) : (
        <>
          <CardIcon site={site} renderContext={renderContext} name={name} url={url} icon={icon} />
          <div class="site-card-content">
            <h3>{name}</h3>
            <p>{description}</p>
          </div>
        </>
      )}
    </a>
  )
}
